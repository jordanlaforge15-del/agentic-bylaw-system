DATABASE_URL=postgresql+psycopg://layer1:layer1@localhost:5432/layer1

# Layer 1 parsing
OCR_ENABLED=false
CAMELOT_ENABLED=false
LOG_LEVEL=INFO
BOILERPLATE_REPETITION_THRESHOLD=2

# Layer 2 LLM. Leave LAYER2_LLM_BASE_URL unset to use the mock LLM.
OPENAI_API_KEY=
LAYER2_LLM_BASE_URL=https://api.openai.com/v1
LAYER2_LLM_API_KEY=
LAYER2_LLM_MODEL=gpt-5.4

# Layer 2 embeddings. Leave LAYER2_EMBEDDING_BASE_URL unset to use hashing embeddings.
LAYER2_EMBEDDING_BASE_URL=
LAYER2_EMBEDDING_API_KEY=
LAYER2_EMBEDDING_MODEL=hashing-bge-small-en-v1.5
LAYER2_EMBEDDING_DIMENSIONS=384

# Layer 2 retrieval and prompt behavior.
LAYER2_PROMPT_VERSION=v1
LAYER2_RETRIEVAL_VERSION=v1
LAYER2_TOKEN_BUDGET=3000
LAYER2_TOP_K=8
LAYER2_MAX_CACHED_CLAIMS=4

AUDIT_LLM_MODEL=gpt-5.4-mini
AUDIT_MAX_BLOCKS_PER_PAGE=40
AUDIT_MAX_FRAGMENTS_PER_PAGE=40
