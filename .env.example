DATABASE_URL=postgresql+psycopg://layer1:layer1@localhost:5432/layer1

# Layer 1 parsing
OCR_ENABLED=false
CAMELOT_ENABLED=false
LOG_LEVEL=INFO
BOILERPLATE_REPETITION_THRESHOLD=2

# Layer 2 LLM. Leave LAYER2_LLM_BASE_URL unset to use the mock LLM.
OPENAI_API_KEY=
LAYER2_LLM_BASE_URL=https://api.openai.com/v1
LAYER2_LLM_API_KEY=
LAYER2_LLM_MODEL=gpt-5.4

# Layer 2 embeddings. Leave LAYER2_EMBEDDING_BASE_URL unset to use hashing embeddings.
LAYER2_EMBEDDING_BASE_URL=
LAYER2_EMBEDDING_API_KEY=
LAYER2_EMBEDDING_MODEL=hashing-bge-small-en-v1.5
LAYER2_EMBEDDING_DIMENSIONS=384

# Layer 2 retrieval and prompt behavior.
LAYER2_PROMPT_VERSION=v1
LAYER2_RETRIEVAL_VERSION=v1
LAYER2_TOKEN_BUDGET=3000
LAYER2_TOP_K=8
LAYER2_MAX_CACHED_CLAIMS=4

AUDIT_LLM_MODEL=gpt-5.4-mini
AUDIT_MAX_BLOCKS_PER_PAGE=40
AUDIT_MAX_FRAGMENTS_PER_PAGE=40

# Google Maps geocoder (civic-address fallback when no in-database
# civic_address dataset is loaded). Leave unset to disable — a WARNING is
# emitted on first attempted use so the silent-skip is diagnosable.
GOOGLE_MAPS_API_KEY=

# ---------------------------------------------------------------------------
# Advisor (Layer 3) — chat API served by `uvicorn advisor.api.main:app`.
# ---------------------------------------------------------------------------

# LLM gateway. ANTHROPIC_API_KEY is required for the production entrypoint.
ADVISOR_LLM_PROVIDER=anthropic
ADVISOR_LLM_MODEL=claude-opus-4-5
ANTHROPIC_API_KEY=

# Clerk auth. Leave CLERK_JWKS_URL unset for local dev — the chat API will
# accept an X-Test-User-Id header instead and log a WARNING at startup.
# Production deployments MUST set all three.
CLERK_JWKS_URL=
CLERK_AUDIENCE=
CLERK_ISSUER=

# Stripe billing. Dormant by default: when ADVISOR_BILLING_ENABLED=false the
# /v1/billing/* endpoints return 503 and no Stripe code path runs. Flip to
# true (and supply the four STRIPE_* values) once a Stripe account exists.
ADVISOR_BILLING_ENABLED=false
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_TEAM=
ADVISOR_BILLING_SUCCESS_URL=http://localhost:3000/billing/success
ADVISOR_BILLING_CANCEL_URL=http://localhost:3000/billing/cancel

# uvicorn host/port for `python -m advisor.api.main`.
ADVISOR_HOST=0.0.0.0
ADVISOR_PORT=8000
