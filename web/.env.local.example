# Clerk authentication (production identity provider).
#
# Get these from your Clerk dashboard → API keys. The publishable
# key is safe to ship to the browser; the secret key MUST stay
# server-side. Setting CLERK_SECRET_KEY is what flips the proxy
# routes (web/app/api/chat/**) out of the dev X-Test-User-Id
# fallback and into real Bearer-JWT mode.
#
# When these are unset the app still boots — middleware will not
# redirect (Clerk's middleware no-ops without keys), and the
# proxy routes fall back to forwarding X-Test-User-Id to the dev
# FastAPI server. That is fine for `npm run dev` against
# `uvicorn advisor.api.dev:app`; never run a public deployment
# without these set.

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace-me
CLERK_SECRET_KEY=sk_test_replace-me

# URLs Clerk's middleware uses to redirect unauthenticated users.
# Match the routes mounted at web/app/sign-in and web/app/sign-up.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Legacy shared-password gate (replaced by Clerk).
#
# Left in place so an operator can roll back to the cookie gate
# without restoring deleted code: re-enable web/middleware.ts's
# previous shared-password version and these two vars become
# meaningful again. Both are read by /api/access at request time.
DEMO_PASSWORD=change-me-before-sharing
ADMIN_PASSWORD=change-me-too-and-keep-private

# Advisor (FastAPI) backend the /api/chat proxy forwards to. Run via:
#   uvicorn advisor.api.dev:app --host 127.0.0.1 --port 8000   (dev)
#   uvicorn advisor.api.main:app --host 0.0.0.0 --port 8000    (prod)
#
# In dev, ADVISOR_DEMO_USER_ID is sent as X-Test-User-Id when
# CLERK_SECRET_KEY is unset — anything stable per-process is fine;
# the backend uses it to key its in-memory session store.
ADVISOR_API_URL=http://127.0.0.1:8000
ADVISOR_DEMO_USER_ID=demo-user-1
