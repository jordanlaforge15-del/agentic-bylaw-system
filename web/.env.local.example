# Shared-password gates for the demo phase.
#
# DEMO_PASSWORD  → required to enter /app (the product itself).
#                  Share this with people you want to demo to.
# ADMIN_PASSWORD → required to enter /admin/invites (the captured
#                  invite-request inbox). Keep this to yourself.
#
# Both are read at request time by the /api/access route. Without them
# set, the /access page will return 503 — safer than silently letting
# everyone through.
#
# Copy this file to .env.local and pick real values. .env.local is
# gitignored by Next's default; never commit real values to .env.local.example.

DEMO_PASSWORD=change-me-before-sharing
ADMIN_PASSWORD=change-me-too-and-keep-private

# Advisor (FastAPI) backend the /api/chat proxy forwards to. Run via:
#   uvicorn advisor.api.dev:app --host 127.0.0.1 --port 8000
# In the dev backend, ADVISOR_DEMO_USER_ID is sent as X-Test-User-Id —
# anything stable per-process is fine; the backend uses it to key
# its in-memory session store. Replace with Clerk JWT bridging later.
ADVISOR_API_URL=http://127.0.0.1:8000
ADVISOR_DEMO_USER_ID=demo-user-1
