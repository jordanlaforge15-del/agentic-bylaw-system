# Clerk authentication (production identity provider).
#
# Leave these commented for `npm run dev` against the dev backend
# (uvicorn advisor.api.dev:app) — Clerk's middleware no-ops when
# the publishable key is absent, the proxy routes fall back to
# forwarding X-Test-User-Id, and the chat sidebar renders the
# static "Halifax Studio" placeholder instead of <UserButton />.
#
# To turn Clerk on, uncomment and set REAL keys from your Clerk
# dashboard → API keys. Placeholder strings (e.g. "pk_test_replace-me")
# WILL crash @clerk/backend at runtime with a "Missing publishableKey"
# error — leave the lines commented until you have real values.
# Never run a public deployment without these set.

# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_…
# CLERK_SECRET_KEY=sk_live_…

# Disables Clerk's "keyless mode" auto-instance + the bottom-right
# "claim your keys" popup that appears in dev when no publishable
# key is set. Always-on is safe: when real keys are present (Clerk
# mode), keyless mode never activates anyway, so this flag has no
# effect. Without it, every page render in dev mode would mount a
# Clerk widget pointing at upstream — embarrassing in front of
# trial users.
NEXT_PUBLIC_CLERK_KEYLESS_DISABLED=true

# URLs Clerk's middleware uses to redirect unauthenticated users.
# Only relevant when the keys above are set. Match the routes mounted
# at web/app/sign-in and web/app/sign-up.
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
# NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Legacy shared-password gate (replaced by Clerk).
#
# Left in place so an operator can roll back to the cookie gate
# without restoring deleted code: re-enable web/middleware.ts's
# previous shared-password version and these two vars become
# meaningful again. Both are read by /api/access at request time.
DEMO_PASSWORD=change-me-before-sharing
ADMIN_PASSWORD=change-me-too-and-keep-private

# Advisor (FastAPI) backend the /api/chat proxy forwards to. Run via:
#   uvicorn advisor.api.dev:app --host 127.0.0.1 --port 8000   (dev)
#   uvicorn advisor.api.main:app --host 0.0.0.0 --port 8000    (prod)
#
# In dev, ADVISOR_DEMO_USER_ID is sent as X-Test-User-Id when
# CLERK_SECRET_KEY is unset — anything stable per-process is fine;
# the backend uses it to key its in-memory session store.
ADVISOR_API_URL=http://127.0.0.1:8000
ADVISOR_DEMO_USER_ID=demo-user-1
